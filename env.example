# ============================================================
# RETICEO Chat Proxy — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter le fichier .env
# ============================================================

# Clé API Anthropic (obligatoire)
# Obtenir sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI

# Port d'écoute du serveur (défaut : 3001)
PORT=3001

# Domaine autorisé en CORS — mettre l'URL exacte du site front-end
# En développement : http://localhost:8080
# En production    : https://www.reticeo.school
ALLOWED_ORIGIN=https://www.reticeo.school

# Environnement : development | production
NODE_ENV=production

# Rate limiting : nombre max de requêtes par IP par fenêtre de 15 min
# Défaut : 20 (suffisant pour un usage normal de chat)
RATE_LIMIT_MAX=20

# Longueur max du message utilisateur en caractères (anti-spam)
MAX_MESSAGE_LENGTH=1000

# Nombre max de tours d'historique transmis au modèle (économie de tokens)
MAX_HISTORY_TURNS=6
